{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Jiyu Music",
  "version": "0.1.1",
  "identifier": "com.jiyu.music",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1520",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Jiyu Music",
        "width": 1440,
        "height": 1055,
        "minWidth": 654,
        "minHeight": 479,
        "resizable": true,
        "acceptFirstMouse": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "fullscreen": false,
        "devtools": true
      },
      {
        "label": "lyrics",
        "title": "Desktop Lyrics",
        "url": "lyrics-window.html",
        "width": 600,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Midnight-Injection",
    "shortDescription": "Jiyu Music Desktop Application",
    "longDescription": "A desktop music application with multi-source search, playback, lyrics and download capabilities.",
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "tsp": false,
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxQjhBOTdEMkVGN0M3MEEKUldRS3gvY3VmYW00d1l3VERxSlg3WEpTbU9MR21EOHhKM2ttbmFkdHZXbkRDNWxTTEVZejBJdE0K",
      "endpoints": [
        "https://github.com/Midnight-Injection/MI_music/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

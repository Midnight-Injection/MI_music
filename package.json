{
  "name": "jiyu-music",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tv": "VITE_UI_MODE=tv vite",
    "dev:mobile": "VITE_UI_MODE=mobile vite",
    "build": "vite build",
    "build:tv": "VITE_UI_MODE=tv vite build",
    "build:mobile": "VITE_UI_MODE=mobile vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "tauri build --target universal-apple-darwin",
    "build:mac-arm": "tauri build --target aarch64-apple-darwin",
    "build:mac-intel": "tauri build --target x86_64-apple-darwin",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "build:all": "npm run build:mac && npm run build:windows && npm run build:linux",
    "build:android": "VITE_UI_MODE=mobile tauri android build",
    "build:android-tv": "VITE_UI_MODE=tv tauri android build",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "VITE_UI_MODE=mobile tauri android dev",
    "test": "vitest run",
    "lint": "eslint src --ext .vue,.ts",
    "lint:fix": "eslint src --ext .vue,.ts --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@types/crypto-js": "^4.2.2",
    "@vicons/ionicons5": "^0.13.0",
    "crypto-js": "^4.2.0",
    "motion-v": "^2.0.0",
    "naive-ui": "^2.44.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "jsdom": "^29.0.1",
    "prettier": "^3.1.1",
    "sass-embedded": "^1.97.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.6.1",
    "vue-tsc": "^3.2.5"
  }
}
